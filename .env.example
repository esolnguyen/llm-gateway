# =============================================================
# llm-wrapper — Environment Variables
# =============================================================
# Copy to .env and fill in values for local development.
# =============================================================

# PostgreSQL (async driver required)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/llm_wrapper

# Symmetric key used with pgcrypto's pgp_sym_decrypt to read credentials.
# Must match the key used at write time when inserting into model_credentials.
CREDENTIAL_ENCRYPTION_KEY=change-me-to-a-long-random-secret

# Optional pool tuning
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
